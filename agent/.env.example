# Terrace settlement agent
INJECTIVE_NETWORK=testnet
POOL_ADDRESS=0x...
# Must match the agent address passed to TerracePool's constructor.
# Needs INJ (settle gas) + USDC (x402 oracle payments).
AGENT_PRIVATE_KEY=0x...
ORACLE_URL=http://localhost:4021
POLL_SECONDS=20
# ORACLE_FREE=true   # dev only: skip x402 when oracle runs X402_MODE=off
# RPC_URL=           # optional override
