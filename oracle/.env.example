# Terrace oracle
PORT=4021
# local (default) = run own facilitator | remote = hosted facilitator | off = dev, no paywall
X402_MODE=local
INJECTIVE_NETWORK=testnet
# Any funded testnet key (INJ for gas). Settles x402 payments on-chain.
FACILITATOR_PRIVATE_KEY=0x...
# Where oracle revenue goes. Defaults to the facilitator wallet if unset.
# PAY_TO=0x...
# Price per result in USDC base units (50000 = $0.05)
RESULT_PRICE_BASE_UNITS=50000
# X402_FACILITATOR_URL=   # only for X402_MODE=remote
# RPC_URL=                # optional override
